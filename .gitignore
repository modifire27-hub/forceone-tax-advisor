# ----------------------------------------------------------------------
# .gitignore — 포스원 세무 자문 AI 시스템
# ----------------------------------------------------------------------
# 이 파일에 적힌 이름의 파일/폴더는 GitHub에 올릴 때 자동으로 제외됩니다.
# 실수로 비밀 값이나 불필요한 파일이 올라가는 것을 막기 위한 안전장치입니다.

# 비밀 값이 들어있는 파일 (절대 업로드 금지)
.env
*.env
forceone-tax-ai-*.json
*.json.key
Streamlit Secrets.txt
streamlit_secrets.txt
.confirm_pin.txt

# 구글 서비스 계정 키 (이름이 다를 경우를 대비해 패턴으로도 제외)
*service-account*.json
*credentials*.json

# 파이썬 캐시/임시 파일
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.zip

# 가상환경 (혹시 폴더 안에 만들어둔 경우)
venv/
.venv/
env/

# 로컬 산출물 (저장된 자문 기록, 코드 저장소에 넣지 않음)
세법검토_아카이브/
*.md.bak

# 내부 검토 문서 (코드 저장소와는 별개로 관리)
개발계획서/

# OS가 자동으로 만드는 파일
.DS_Store
Thumbs.db

# 에디터 설정 파일
.vscode/
.idea/
